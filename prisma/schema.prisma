generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("STAFF")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Floor {
  id     String @id @default(cuid())
  number Int    @unique
  name   String?
  rooms  Room[]
}

model Room {
  id       String    @id @default(cuid())
  number   String    @unique
  type     String
  price    Float
  status   String    @default("AVAILABLE")
  floorId  String?
  bookings Booking[]
  floor    Floor?    @relation(fields: [floorId], references: [id], onDelete: Cascade)

  @@index([floorId])
  @@index([status])
}

model Guest {
  id          String    @id @default(cuid())
  name        String
  email       String?   @unique
  phone       String?
  nationality String?
  bookings    Booking[]
}

model Booking {
  id                 String          @id @default(cuid())
  roomId             String
  guestId            String
  checkIn            DateTime
  checkOut           DateTime
  status             String          @default("CONFIRMED")
  totalAmount        Float
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  cancellationReason String?
  source             String          @default("DIRECT")
  guest              Guest           @relation(fields: [guestId], references: [id])
  room               Room            @relation(fields: [roomId], references: [id])
  serviceCharges     ServiceCharge[]

  @@index([status])
  @@index([roomId])
  @@index([guestId])
  @@index([checkIn])
  @@index([checkOut])
  @@index([createdAt])
  // Composite for date-range occupancy queries (dashboard)
  @@index([status, checkIn, checkOut])
}

model ConferenceRoom {
  id           String              @id @default(cuid())
  name         String
  capacity     Int
  pricePerHour Float
  bookings     ConferenceBooking[]
}

model ConferenceBooking {
  id               String         @id @default(cuid())
  conferenceRoomId String
  guestName        String
  guestContact     String?
  guestId          String?
  guestEmail       String?
  startTime        DateTime
  endTime          DateTime
  totalAmount      Float
  status           String         @default("CONFIRMED")
  createdAt        DateTime       @default(now())
  conferenceRoom   ConferenceRoom @relation(fields: [conferenceRoomId], references: [id])

  @@index([conferenceRoomId])
  @@index([status])
  @@index([startTime, endTime])
}

model Service {
  id      String          @id @default(cuid())
  name    String          @unique
  price   Float
  unit    String
  charges ServiceCharge[]
}

model ServiceCharge {
  id           String   @id @default(cuid())
  bookingId    String?
  serviceId    String
  guestName    String?
  guestContact String?
  status       String   @default("PENDING")
  quantity     Int      @default(1)
  totalPrice   Float
  date         DateTime @default(now())
  booking      Booking? @relation(fields: [bookingId], references: [id])
  service      Service  @relation(fields: [serviceId], references: [id])

  @@index([bookingId])
  @@index([serviceId])
  @@index([status])
  @@index([date])
}

model WebInquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("NEW")
  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  message   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
}

model InventoryItem {
  id        String   @id @default(cuid())
  name      String
  category  String
  stock     Int
  unit      String
  minStock  Int      @default(10)
  price     Float
  updatedAt DateTime @updatedAt

  @@index([category])
}

model MenuItem {
  id          String  @id @default(cuid())
  name        String
  category    String
  price       Float
  description String?
  available   Boolean @default(true)

  @@index([available])
  @@index([category])
}

model Invoice {
  id              String        @id @default(cuid())
  guestName       String
  amount          Float
  status          String        @default("UNPAID")
  date            DateTime      @default(now())
  guestSignature  String?
  masterInvoiceId String?
  type            String        @default("ROOM")
  masterInvoice   Invoice?      @relation("MasterToSub", fields: [masterInvoiceId], references: [id])
  subInvoices     Invoice[]     @relation("MasterToSub")
  items           InvoiceItem[]

  @@index([masterInvoiceId])
  @@index([status])
  @@index([date])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int
  price       Float
  invoice     Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
}
