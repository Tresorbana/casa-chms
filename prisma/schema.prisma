generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("STAFF")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Floor {
  id     String @id @default(cuid())
  number Int    @unique
  name   String?
  rooms  Room[]
}

model Room {
  id       String    @id @default(cuid())
  number   String    @unique
  type     String
  price    Float
  status   String    @default("AVAILABLE")
  floorId  String?
  bookings Booking[]
  invoices Invoice[]
  floor    Floor?    @relation(fields: [floorId], references: [id], onDelete: Cascade)

  @@index([floorId])
  @@index([status])
}

model Guest {
  id          String    @id @default(cuid())
  name        String
  email       String?   @unique
  phone       String?
  nationality String?
  bookings    Booking[]
}

model Booking {
  id                 String          @id @default(cuid())
  roomId             String
  guestId            String
  checkIn            DateTime
  checkOut           DateTime
  status             String          @default("CONFIRMED")
  totalAmount        Float
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  cancellationReason String?
  source             String          @default("DIRECT")
  checkedInAt        DateTime?
  checkedOutAt       DateTime?
  createdByName      String?
  guest              Guest           @relation(fields: [guestId], references: [id])
  room               Room            @relation(fields: [roomId], references: [id])
  serviceCharges     ServiceCharge[]

  @@index([status])
  @@index([roomId])
  @@index([guestId])
  @@index([checkIn])
  @@index([checkOut])
  @@index([createdAt])
  // Composite for date-range occupancy queries (dashboard)
  @@index([status, checkIn, checkOut])
}

model ConferenceRoom {
  id           String              @id @default(cuid())
  name         String
  capacity     Int
  pricePerHour Float
  pricePerDay  Float               @default(0)
  bookings     ConferenceBooking[]
}

model ConferenceBooking {
  id               String                  @id @default(cuid())
  conferenceRoomId String
  guestName        String
  guestContact     String?
  guestId          String?
  guestEmail       String?
  bookingType      String                  @default("HOURLY")
  startTime        DateTime
  endTime          DateTime
  totalAmount      Float
  status           String                  @default("CONFIRMED")
  createdAt        DateTime                @default(now())
  invoiceId        String?
  linkedBookingIds String[]
  notes            String?
  checkedInAt      DateTime?
  checkedOutAt     DateTime?
  createdByName    String?
  conferenceRoom   ConferenceRoom          @relation(fields: [conferenceRoomId], references: [id])
  items            ConferenceBookingItem[]

  @@index([conferenceRoomId])
  @@index([status])
  @@index([startTime, endTime])
}

model Service {
  id      String          @id @default(cuid())
  name    String          @unique
  price   Float
  unit    String
  charges ServiceCharge[]
}

model ServiceCharge {
  id           String   @id @default(cuid())
  bookingId    String?
  serviceId    String
  guestName    String?
  guestContact String?
  status       String   @default("PENDING")
  quantity     Int      @default(1)
  totalPrice   Float
  date         DateTime @default(now())
  booking      Booking? @relation(fields: [bookingId], references: [id])
  service      Service  @relation(fields: [serviceId], references: [id])

  @@index([bookingId])
  @@index([serviceId])
  @@index([status])
  @@index([date])
}

model WebInquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("NEW")
  checkIn   DateTime?
  checkOut  DateTime?
  guests    Int?
  roomType  String?
  response  String?
  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}


model Notification {
  id          String   @id @default(cuid())
  message     String
  type        String   @default("INFO")
  isRead      Boolean  @default(false)
  targetRoles String[] @default([])
  createdAt   DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
}

model InventoryItem {
  id               String          @id @default(cuid())
  name             String
  category         String
  stock            Int
  unit             String
  minStock         Int             @default(10)
  price            Float
  updatedAt        DateTime        @updatedAt
  linkedMenuItemId String?
  movements        StockMovement[]

  @@index([category])
}

model MenuItem {
  id              String  @id @default(cuid())
  name            String
  category        String
  price           Float
  description     String?
  available       Boolean @default(true)
  inventoryItemId String?

  @@index([available])
  @@index([category])
}

model Invoice {
  id              String        @id @default(cuid())
  guestName       String
  amount          Float
  status          String        @default("UNPAID")
  paymentMethod   String?
  paidAt          DateTime?
  date            DateTime      @default(now())
  guestSignature  String?
  masterInvoiceId String?
  type            String        @default("ROOM")
  roomId          String?
  createdByName   String?
  createdById     String?
  masterInvoice   Invoice?      @relation("MasterToSub", fields: [masterInvoiceId], references: [id])
  subInvoices     Invoice[]     @relation("MasterToSub")
  items           InvoiceItem[]
  room            Room?         @relation(fields: [roomId], references: [id])

  @@index([masterInvoiceId])
  @@index([status])
  @@index([date])
  @@index([createdById])
  @@index([roomId])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int
  price       Float
  invoice     Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
}

model StockMovement {
  id        String        @id @default(cuid())
  itemId    String
  type      String        // "IN" | "OUT"
  quantity  Int
  reason    String?       // "PURCHASE" | "RESTAURANT_SALE" | "MANUAL_ADJUSTMENT" | "WASTE" | "INITIAL"
  reference String?       // invoice ID or note
  createdAt DateTime      @default(now())
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([type])
  @@index([createdAt])
}

model Expense {
  id            String   @id @default(cuid())
  category      String   // "UTILITIES" | "SUPPLIES" | "SALARIES" | "MAINTENANCE" | "FOOD_PURCHASE" | "MARKETING" | "OTHER"
  description   String
  amount        Float
  date          DateTime @default(now())
  paymentMethod String?
  vendor        String?
  createdAt     DateTime @default(now())

  @@index([category])
  @@index([date])
}

model ConferenceBookingItem {
  id                  String            @id @default(cuid())
  conferenceBookingId String
  description         String
  quantity            Int               @default(1)
  unitPrice           Float
  totalPrice          Float
  conferenceBooking   ConferenceBooking @relation(fields: [conferenceBookingId], references: [id], onDelete: Cascade)

  @@index([conferenceBookingId])
}

model OtherIncome {
  id            String   @id @default(cuid())
  description   String
  amount        Float
  category      String   @default("OTHER")
  date          DateTime @default(now())
  paymentMethod String?
  source        String?
  createdAt     DateTime @default(now())
  createdByName String?

  @@index([date])
  @@index([category])
}
